<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    tools:context=".FavoritesActivity">

    <ImageButton
        android:id="@+id/btnFavoritesBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/details_back"
        android:padding="8dp"
        android:src="@drawable/outline_arrow_left_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black" />

    <TextView
        android:id="@+id/txtFavoritesTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/favorites_title"
        android:textColor="@color/black"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnFavoritesBack"
        app:layout_constraintEnd_toStartOf="@id/switchlanguage"
        app:layout_constraintStart_toEndOf="@id/btnFavoritesBack"
        app:layout_constraintTop_toTopOf="@id/btnFavoritesBack" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchlanguage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/switch_language_en"
        android:textColor="@color/black"
        app:layout_constraintBottom_toBottomOf="@id/btnFavoritesBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnFavoritesBack" />

    <TextView
        android:id="@+id/txtOfflineBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@color/yellow"
        android:padding="8dp"
        android:text="@string/offline_banner_text"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnFavoritesBack" />

    <LinearLayout
        android:id="@+id/emptyStateContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtOfflineBanner">

        <ImageView
            android:id="@+id/imgFavoritesEmpty"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:contentDescription="@string/favorites_empty_title"
            android:src="@android:drawable/ic_menu_gallery"
            app:tint="@color/grey" />

        <TextView
            android:id="@+id/txtFavoritesEmptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/favorites_empty_title"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtFavoritesEmptySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/favorites_empty_subtitle"
            android:textColor="@color/grey"
            android:textSize="14sp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerFavorites"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtOfflineBanner" />

</androidx.constraintlayout.widget.ConstraintLayout>


